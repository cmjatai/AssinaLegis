<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="br.leg.go.jatai.assinalegis.DocumentViewerController"
      alignment="CENTER"
      stylesheets="@styles.css">

    <VBox fx:id="vBoxListProps" spacing="0" alignment="CENTER" prefWidth="400.0" minWidth="400.0" maxWidth="400.0" HBox.hgrow="NEVER" style="-fx-background-color: #f0f0f0;">
        <HBox alignment="CENTER_LEFT" spacing="5">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <Label text="Documentos para Assinatura" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Button text="Atualizar" onAction="#onRefreshDocuments"/>
        </HBox>
        <ListView fx:id="documentListView" VBox.vgrow="ALWAYS"/>
    </VBox>
    <VBox fx:id="vBoxPreviewPage" spacing="0" alignment="CENTER" prefWidth="800.0">
        <HBox alignment="CENTER" spacing="0">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <Button fx:id="btnFirstPage" text="&lt;&lt;" onAction="#onFirstPage"/>
            <Button fx:id="btnPrevPage" text="&lt;" onAction="#onPrevPage"/>
            <Button fx:id="btnZoomOut" text="-" onAction="#onZoomOut"/>
            <Button fx:id="btnFitWidth" text="Ajustar Largura" onAction="#onFitWidth"/>
            <Button fx:id="btnZoomIn" text="+" onAction="#onZoomIn"/>
            <Button fx:id="btnNextPage" text="&gt;" onAction="#onNextPage"/>
            <Button fx:id="btnLastPage" text="&gt;&gt;" onAction="#onLastPage"/>
        </HBox>

        <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="true" pannable="true" style="-fx-background-color: #aaaaaa;">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <StackPane fx:id="contentHolder"  style="-fx-background-color: #aaaaaa;"/>
        </ScrollPane>
    </VBox>

</HBox>
